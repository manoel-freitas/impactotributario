# ─── Reforma Tributária Simulator — Environment Variables ─────────────────────
# Copy this file to .env and fill in the values

# Google AdSense Publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
# Required for display ads. Replace with your actual publisher ID from AdSense dashboard.
PUBLIC_ADSENSE_PUBLISHER_ID=

# Optional: deploy hook URLs (used in GitHub Actions, not needed locally)
# CF_DEPLOY_HOOK=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/...
# NETLIFY_DEPLOY_HOOK=https://api.netlify.com/build_hooks/...
