---
import GlossaryPageLayout from "../layouts/GlossaryPageLayout.astro";

const title = "Lucro Real — Reforma Tributária 2026 | Guia Completo";
const description = "Entenda como o Lucro Real se beneficia do sistema de Credits do IVA Dual. Obrigatório para empresas acima de R$78M/ano.";
const articleUrl = "https://simuladortributario.com.br/lucro-real";

const faqs = [
  {
    q: "O Lucro Real se beneficia da reforma?",
    a: "Sim. Empresas no Lucro Real podem se beneficiar mais do sistema não cumulativo do IVA Dual, especialmente aquelas com alta cadeia de insumos. Quanto mais etapas de produção, mais créditos podem ser apurados."
  },
  {
    q: "Como funciona o sistema de créditos?",
    a: "O CBS e IBS pagos em cada etapa podem ser creditados contra o imposto devido nas etapas seguintes. Isso elimina a cumulatividade (imposto sobre imposto) e reduz o custo real de tributação."
  },
  {
    q: "Quando muda para Lucro Real?",
    a: "A timeline é a mesma: 2026 informativo, 2027 CBS entra em vigor, 2029-2033 IBS entra gradualmente. A diferença é que Lucro Real pode se beneficiar plenamente dos créditos desde o início."
  },
  {
    q: "É obrigatório acima de quanto?",
    a: "Empresas com faturamento acima de R$78M/ano são obrigadas a estar no Lucro Real. Também há obrigatoriedade por setor (bancos, seguros, etc.) e para quem opta por incentivos fiscais."
  }
];

const seeAlso = [
  { href: "/glossario", title: "Glossário", description: "Todos os termos da reforma" },
  { href: "/lucro-presumido", title: "Lucro Presumido", description: "Até R$78M/ano" },
  { href: "/iva-dual", title: "IVA Dual", description: "Sistema CBS + IBS" },
  { href: "/", title: "Simulador Gratuito", description: "Calcule o impacto no seu negócio" }
];
---

<GlossaryPageLayout
  title={title}
  description={description}
  articleUrl={articleUrl}
  badge="Lucro Real"
  badgeClass="bg-[#001E40] text-white"
  heroTitle="Lucro Real na Reforma"
  heroSubtitle="Maior benefício do sistema não cumulativo: créditos IVA integrais."
  statValue="Créditos IVA"
  statLabel="Integrais"
  statDetails={["Não cumulativo", "Alta cadeia de insumos", "Benefício máximo"]}
  faqTitle="Perguntas Frequentes — Lucro Real"
  faqs={faqs}
  ctaTitle="Pronto para calcular o impacto?"
  ctaText="Simule quanto a reforma tributária vai afetar o seu negócio com base no seu regime e faturamento."
  ctaLink="/"
  ctaLinkText="Simular impacto no meu negócio"
  seeAlso={seeAlso}
>
  <!-- Timeline Slot -->
  <div slot="timeline" class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-headline font-bold text-[#001E40] mb-12">
      Linha do Tempo: Lucro Real
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1fr_2fr] gap-8 md:gap-6">
      <!-- 2026 -->
      <article class="bg-[#FBF9F9] rounded-xl p-6 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-[#001E40]" style="font-variation-settings: 'FILL' 1;">info</span>
          <h3 class="text-lg font-headline font-bold text-[#001E40]">2026</h3>
        </div>
        <p class="text-[#43474F] mb-4">Informativo</p>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#5E6F83] text-lg" style="font-variation-settings: 'FILL' 1;">remove</span>
            CBS/IBS em notas
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#5E6F83] text-lg" style="font-variation-settings: 'FILL' 1;">remove</span>
            Sem cobrança
          </li>
        </ul>
      </article>

      <!-- 2027 -->
      <article class="bg-[#FBF9F9] rounded-xl p-6 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-[#002F74]" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
          <h3 class="text-lg font-headline font-bold text-[#001E40]">2027</h3>
        </div>
        <p class="text-[#43474F] mb-4">CBS + Créditos</p>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#006C4B] text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            CBS cobrada
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#006C4B] text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            Créditos ativos
          </li>
        </ul>
      </article>

      <!-- 2029 -->
      <article class="bg-[#FBF9F9] rounded-xl p-6 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-[#002F74]" style="font-variation-settings: 'FILL' 1;">trending_up</span>
          <h3 class="text-lg font-headline font-bold text-[#001E40]">2029</h3>
        </div>
        <p class="text-[#43474F] mb-4">IBS + Créditos</p>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#006C4B] text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            IBS (10%)
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#006C4B] text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            Créditos IBS
          </li>
        </ul>
      </article>

      <!-- 2033+ -->
      <article class="bg-[#001E40] rounded-xl p-6 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-[#9AF5CA]/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="relative">
          <div class="flex items-center gap-3 mb-4">
            <span class="material-symbols-outlined text-[#9AF5CA]" style="font-variation-settings: 'FILL' 1;">verified</span>
            <h3 class="text-lg font-headline font-bold">2033+</h3>
          </div>
          <p class="text-white/70 mb-4">Créditos plenos</p>
          <div class="bg-[#9AF5CA]/10 rounded-lg p-4 border-l-4 border-[#9AF5CA]">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-[#9AF5CA]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
              <span class="font-headline font-bold text-[#9AF5CA]">IVA Dual completo</span>
            </div>
            <p class="text-sm text-white/60">CBS + IBS plenos com créditos integrais.</p>
          </div>
        </div>
      </article>
    </div>
  </div>

  <!-- Content Slot -->
  <div slot="content">
    <section>
      <h2 class="text-xl font-headline font-bold text-[#001E40] mb-4">Por que o Lucro Real se beneficia mais?</h2>
      <p class="text-base text-[#43474F] leading-relaxed">
        Empresas no Lucro Real têm obrigações que permitem apurar custos reais e, consequentemente, aprovechar melhor o sistema de créditos do IVA Dual. Quanto mais complexa a cadeia de produção, maior o benefício.
      </p>
      <p class="text-base text-[#43474F] leading-relaxed mt-4">
        <strong>Benefício principal:</strong> eliminatede da cumulatividade. No sistema atual, o PIS/COFINS incide sobre o imposto já pago em etapas anteriores. Com o IVA não cumulativo, cada empresa abate o imposto pago nos insumos.
      </p>
    </section>

    <section>
      <h2 class="text-xl font-headline font-bold text-[#001E40] mb-4">Como funcionam os créditos?</h2>
      <ul class="list-disc pl-5 space-y-2 text-[#43474F]">
        <li><strong>Crédito de CBS:</strong> pode ser abatido do CBS devido sobre vendas</li>
        <li><strong>Crédito de IBS:</strong> idem, para o IBS estadual e municipal</li>
        <li><strong>Crédito misto:</strong> em operações de venda de produtos + serviços</li>
        <li><strong>Saldo credor:</strong> pode ser compensado com outros tributos ou solicitado</li>
      </ul>
    </section>

    <section>
      <h2 class="text-xl font-headline font-bold text-[#001E40] mb-4">Obrigatoriedade</h2>
      <p class="text-[#43474F] mb-4">
        O Lucro Real é obrigatório para:
      </p>
      <ul class="list-disc pl-5 space-y-2 text-[#43474F]">
        <li>Empresas com faturamento acima de R$78M/ano</li>
        <li>Bancos e instituições financeiras</li>
        <li>Seguradoras e planos de saúde</li>
        <li>Empresas que optam por incentivos fiscais (LUCRO REAL)</li>
        <li>一些 setores específicos (impostos específicos)</li>
      </ul>
    </section>
  </div>
</GlossaryPageLayout>