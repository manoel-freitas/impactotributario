---
import GlossaryPageLayout from "../layouts/GlossaryPageLayout.astro";

const title = "Split Payment — Retenção Automática de Impostos | Guia Completo";
const description = "Entenda o Split Payment: mecanismo de retenção automática do CBS e IBS no momento do pagamento. Como afeta o fluxo de caixa das empresas.";
const articleUrl = "https://impactotributario.com/split-payment";

const faqs = [
  {
    q: "O que é Split Payment?",
    a: "É o mecanismo de retenção automática do imposto no momento do pagamento. Quando o cliente paga via Pix ou cartão, o sistema bancário separa automaticamente a parte relativa ao CBS antes de repassar o valor à empresa. Elimina o modelo declaratório tradicional."
  },
  {
    q: "Como afeta meu fluxo de caixa?",
    a: "A empresa recebe o valor já líquido, sem precisar calcular e recolher o imposto depois. Porém, perde o direito de usar o imposto recolhido como capital de giro durante o month. O impacto varia conforme o volume de vendas."
  },
  {
    q: "O MEI é afetado pelo Split Payment?",
    a: "Não. MEI (até R$81.000/ano) está isento de CBS e IBS pela LC 214/2025. O Split Payment só afeta contribuintes sujeitos às novas alíquotas."
  },
  {
    q: "Preciso fazer algo para implementar?",
    a: "Seus clientes PJ (que compram de você) é que farão a retenção. Mas você precisa informar o CNPJ correto nas notas fiscais para que o sistema identifique o rateio. Empresas no regime de Split Payment devem adaptar seus sistemas."
  }
];

const seeAlso = [
  { href: "/glossario", title: "Glossário", description: "Todos os termos da reforma" },
  { href: "/iva-dual", title: "IVA Dual", description: "Sistema CBS + IBS" },
  { href: "/simples-nacional", title: "Simples Nacional", description: " CBS e IBS no DAS a partir de 2027" },
  { href: "/", title: "Simulador Gratuito", description: "Calcule o impacto no seu negócio" }
];
---

<GlossaryPageLayout
  title={title}
  description={description}
  articleUrl={articleUrl}
  badge="Split Payment"
  badgeClass="bg-[#002F74] text-white"
  heroTitle="Split Payment na Reforma"
  heroSubtitle="Retenção automática de CBS e IBS no momento do pagamento."
  statValue="Retenção automática"
  statLabel="Na fonte"
  statDetails={["Via Pix ou cartão", "Sem declaração", "Fluxo de caixa alterado"]}
  faqTitle="Perguntas Frequentes — Split Payment"
  faqs={faqs}
  ctaTitle="Pronto para calcular o impacto?"
  ctaText="Simule quanto a reforma tributária vai afetar o seu negócio com base no seu regime e setor."
  ctaLink="/"
  ctaLinkText="Simular impacto no meu negócio"
  seeAlso={seeAlso}
>
  <!-- Timeline Slot -->
  <div slot="timeline" class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-headline font-bold text-[#001E40] mb-12">
      Linha do Tempo: Split Payment
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1fr_2fr] gap-8 md:gap-6">
      <!-- 2026 -->
      <article class="bg-[#FBF9F9] rounded-xl p-6 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-[#001E40]" style="font-variation-settings: 'FILL' 1;">info</span>
          <h3 class="text-lg font-headline font-bold text-[#001E40]">2026</h3>
        </div>
        <p class="text-[#43474F] mb-4">Piloto</p>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#5E6F83] text-lg" style="font-variation-settings: 'FILL' 1;">remove</span>
            Split via Pix
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#5E6F83] text-lg" style="font-variation-settings: 'FILL' 1;">remove</span>
            only informativo
          </li>
        </ul>
      </article>

      <!-- 2027 -->
      <article class="bg-[#FBF9F9] rounded-xl p-6 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-[#002F74]" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
          <h3 class="text-lg font-headline font-bold text-[#001E40]">2027</h3>
        </div>
        <p class="text-[#43474F] mb-4">CBS via Split</p>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#006C4B] text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            CBS retida
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#5E6F83] text-lg" style="font-variation-settings: 'FILL' 1;">remove</span>
            IBS ainda não
          </li>
        </ul>
      </article>

      <!-- 2029 -->
      <article class="bg-[#FBF9F9] rounded-xl p-6 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-[#002F74]" style="font-variation-settings: 'FILL' 1;">trending_up</span>
          <h3 class="text-lg font-headline font-bold text-[#001E40]">2029</h3>
        </div>
        <p class="text-[#43474F] mb-4">IBS entra</p>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#006C4B] text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            IBS retido
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#006C4B] text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            CBS retido
          </li>
        </ul>
      </article>

      <!-- 2033+ -->
      <article class="bg-[#001E40] rounded-xl p-6 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-[#9AF5CA]/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="relative">
          <div class="flex items-center gap-3 mb-4">
            <span class="material-symbols-outlined text-[#9AF5CA]" style="font-variation-settings: 'FILL' 1;">verified</span>
            <h3 class="text-lg font-headline font-bold">2033+</h3>
          </div>
          <p class="text-white/70 mb-4">Split pleno</p>
          <div class="bg-[#9AF5CA]/10 rounded-lg p-4 border-l-4 border-[#9AF5CA]">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-[#9AF5CA]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
              <span class="font-headline font-bold text-[#9AF5CA]">Todos os métodos</span>
            </div>
            <p class="text-sm text-white/60">Pix, cartão, TED, DOC, boleto — todos com retenção automática.</p>
          </div>
        </div>
      </article>
    </div>
  </div>

  <!-- Content Slot -->
  <div slot="content">
    <section>
      <h2 class="text-xl font-headline font-bold text-[#001E40] mb-4">O que é Split Payment?</h2>
      <p class="text-base text-[#43474F] leading-relaxed">
        O Split Payment é um mecanismo de <strong>retenção automática</strong> do imposto no momento do pagamento. Quando um cliente paga uma compra via Pix ou cartão, o sistema bancário ou de pagamento separa automaticamente a parte relativa ao CBS (e futuramente IBS) antes de repassar o valor restante à empresa.
      </p>
      <p class="text-base text-[#43474F] leading-relaxed mt-4">
        Este modelo substitui o sistema declaratório tradicional, onde a empresa calculava o imposto devido e recolhia depois — frequentemente com prazos de 30 a 90 dias após a venda. Com o Split, o imposto é retido no ato.
      </p>
    </section>

    <section>
      <h2 class="text-xl font-headline font-bold text-[#001E40] mb-4">Como afeta o fluxo de caixa?</h2>
      <ul class="list-disc pl-5 space-y-2 text-[#43474F]">
        <li><strong>Empresa recebe líquido:</strong> o valor depositado já vem descontado do imposto</li>
        <li><strong>Sem necessidade de cálculo:</strong> o banco faz a retenção automaticamente</li>
        <li><strong>Sem prazo de recolhimento:</strong> não há espera entre venda e recolhimento</li>
        <li><strong>Perda de capital de giro:</strong> antes usava o imposto como fundo de prazo; agora não</li>
      </ul>
    </section>

    <section>
      <h2 class="text-xl font-headline font-bold text-[#001E40] mb-4">Quem é afetado?</h2>
      <p class="text-[#43474F] mb-4">
        O Split Payment afeta principalmente empresas sujetas à CBS/IBS com alíquotas plenas. Alguns setores podem ter regras específicas:
      </p>
      <ul class="list-disc pl-5 space-y-2 text-[#43474F]">
        <li><strong>Prestadores de serviço</strong> para PJ</li>
        <li><strong>Vendas para empresas</strong> no Lucro Presumido ou Lucro Real</li>
        <li><strong>Comércio atacadista</strong> com clientes corporativos</li>
      </ul>
      <p class="text-[#43474F] mt-4 text-sm">
        MEI e pequenas empresas no Simples com faturamento baixo podem ter tratamento diferenciado.
      </p>
    </section>
  </div>
</GlossaryPageLayout>