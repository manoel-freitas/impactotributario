---
import GlossaryPageLayout from "../layouts/GlossaryPageLayout.astro";

const title = "Período de Transição 2026–2033 | Guia Completo";
const description = "Entenda a transição da Reforma Tributária: 7 anos de coexistence dos sistemas antigo e novo. Cronograma completo das mudanças.";
const articleUrl = "https://simuladortributario.com.br/transicao";

const faqs = [
  {
    q: "Quanto tempo dura a transição?",
    a: "A transição dura 7 anos (2026–2033). Começa com CBS/IBS informativos em 2026, CBS cobrada em 2027, IBS entra gradualmente em 2029, e sistema pleno em 2033 quando os impostos antigos são extintos."
  },
  {
    q: "Posso escolher quando migrar?",
    a: "Não exatamente. A transição tem regras definidas por lei. Porém, empresas podem se preparar antecipadamente e opt ar por regimes benefícios durante o período. O timing depende do faturamento e setor."
  },
  {
    q: "O que muda especificamente em 2026?",
    a: "Em 2026, CBS e IBS aparecem nas notas fiscais de forma informativa apenas — sem cobrança. É o ano para adaptar sistemas e entender o novo modelo sem impacto financeiro."
  },
  {
    q: "Quando o impacto é maior?",
    a: "O impacto financeiro começa em 2027 (CBS) e 2029 (IBS). O ano de maior mudança é 2033, quando os impostos antigos (PIS, COFINS, ICMS, ISS) são extintos e CBS/IBS ficam plenos."
  }
];

const seeAlso = [
  { href: "/glossario", title: "Glossário", description: "Todos os termos da reforma" },
  { href: "/cronograma", title: "Cronograma", description: "Datas detalhadas" },
  { href: "/iva-dual", title: "IVA Dual", description: "Sistema CBS + IBS" },
  { href: "/", title: "Simulador Gratuito", description: "Calcule o impacto no seu negócio" }
];
---

<GlossaryPageLayout
  title={title}
  description={description}
  articleUrl={articleUrl}
  badge="Transição"
  badgeClass="bg-[#002F74] text-white"
  heroTitle="Transição da Reforma Tributária"
  heroSubtitle="Sete anos de adaptação: 2026–2033."
  statValue="7 anos"
  statLabel="2026–2033"
  statDetails={["CBS informativa 2026", "CBS cobrada 2027", "IBS gradual 2029–2033"]}
  faqTitle="Perguntas Frequentes — Transição"
  faqs={faqs}
  ctaTitle="Pronto para calcular o impacto?"
  ctaText="Simule quanto a reforma tributária vai afetar o seu negócio com base no seu regime e faturamento."
  ctaLink="/"
  ctaLinkText="Simular impacto no meu negócio"
  seeAlso={seeAlso}
>
  <!-- Timeline Slot -->
  <div slot="timeline" class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-headline font-bold text-[#001E40] mb-12">
      Cronograma: Ano a Ano
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1fr_1fr_2fr] gap-4 md:gap-4">
      <!-- 2026 -->
      <article class="bg-[#FBF9F9] rounded-xl p-5 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-2 mb-3">
          <span class="material-symbols-outlined text-[#001E40] text-xl" style="font-variation-settings: 'FILL' 1;">info</span>
          <h3 class="text-base font-headline font-bold text-[#001E40]">2026</h3>
        </div>
        <p class="text-[#43474F] text-sm mb-3">Informativo</p>
        <ul class="space-y-1 text-xs text-[#5E6F83]">
          <li>• CBS/IBS em NF</li>
          <li>• Sem cobrança</li>
          <li>• Adaptar sistemas</li>
        </ul>
      </article>

      <!-- 2027 -->
      <article class="bg-[#FBF9F9] rounded-xl p-5 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-2 mb-3">
          <span class="material-symbols-outlined text-[#002F74] text-xl" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
          <h3 class="text-base font-headline font-bold text-[#001E40]">2027</h3>
        </div>
        <p class="text-[#43474F] text-sm mb-3">CBS entra</p>
        <ul class="space-y-1 text-xs text-[#5E6F83]">
          <li>• CBS cobrada</li>
          <li>• ~8,4%</li>
          <li>• PIS/COFINS extinto</li>
        </ul>
      </article>

      <!-- 2028 -->
      <article class="bg-[#FBF9F9] rounded-xl p-5 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-2 mb-3">
          <span class="material-symbols-outlined text-[#002F74] text-xl" style="font-variation-settings: 'FILL' 1;">trending_up</span>
          <h3 class="text-base font-headline font-bold text-[#001E40]">2028</h3>
        </div>
        <p class="text-[#43474F] text-sm mb-3">Ajustes</p>
        <ul class="space-y-1 text-xs text-[#5E6F83]">
          <li>• CBS plena</li>
          <li>• IBS ainda não</li>
          <li>• Avaliar impacto</li>
        </ul>
      </article>

      <!-- 2029 -->
      <article class="bg-[#FBF9F9] rounded-xl p-5 border border-[#C3C6D1]/20">
        <div class="flex items-center gap-2 mb-3">
          <span class="material-symbols-outlined text-[#002F74] text-xl" style="font-variation-settings: 'FILL' 1;">update</span>
          <h3 class="text-base font-headline font-bold text-[#001E40]">2029</h3>
        </div>
        <p class="text-[#43474F] text-sm mb-3">IBS inicia</p>
        <ul class="space-y-1 text-xs text-[#5E6F83]">
          <li>• IBS (10%)</li>
          <li>• CBS plena</li>
          <li>• ICMS reduz</li>
        </ul>
      </article>

      <!-- 2033 -->
      <article class="bg-[#001E40] rounded-xl p-5 text-white">
        <div class="flex items-center gap-2 mb-3">
          <span class="material-symbols-outlined text-[#9AF5CA] text-xl" style="font-variation-settings: 'FILL' 1;">verified</span>
          <h3 class="text-base font-headline font-bold">2033+</h3>
        </div>
        <p class="text-white/70 text-sm mb-3">Sistema pleno</p>
        <ul class="space-y-1 text-xs text-white/50">
          <li>• CBS + IBS plenos</li>
          <li>• Impostos antigos</li>
          <li>• Extintos</li>
        </ul>
      </article>
    </div>
  </div>

  <!-- Content Slot -->
  <div slot="content">
    <section>
      <h2 class="text-xl font-headline font-bold text-[#001E40] mb-4">Por que 7 anos de transição?</h2>
      <p class="text-base text-[#43474F] leading-relaxed">
        A transição longa serve para que empresas, governos e cidadãos se adaptem ao novo sistema sem choques abruptos. Permite:
      </p>
      <ul class="list-disc pl-5 space-y-2 text-[#43474F] mt-4">
        <li>Atualização de sistemas de notas fiscais</li>
        <li>Planejamento tributário por parte das empresas</li>
        <li>Formação de administris tadores públicos</li>
        <li>Gradualismo politico para aprovação do novo sistema</li>
      </ul>
    </section>

    <section>
      <h2 class="text-xl font-headline font-bold text-[#001E40] mb-4">Quais impostos são extintos?</h2>
      <ul class="list-disc pl-5 space-y-2 text-[#43474F]">
        <li><strong>PIS</strong> → CBS (federal)</li>
        <li><strong>COFINS</strong> → CBS (federal)</li>
        <li><strong>ICMS</strong> → IBS (estadual)</li>
        <li><strong>ISS</strong> → IBS (municipal)</li>
      </ul>
    </section>

    <section>
      <h2 class="text-xl font-headline font-bold text-[#001E40] mb-4">O que fazer em cada fase?</h2>
      <div class="space-y-4">
        <div class="border-l-4 border-[#C3C6D1] pl-4">
          <h3 class="font-semibold text-[#001E40]">2026 — Ano de preparação</h3>
          <p class="text-sm text-[#43474F]">Adapte sistemas de NF-e para incluir CBS/IBS. Não há impacto financeiro.</p>
        </div>
        <div class="border-l-4 border-[#002F74] pl-4">
          <h3 class="font-semibold text-[#001E40]">2027 — CBS entra</h3>
          <p class="text-sm text-[#43474F]">Planeje liquidez para CBS (~8,4%). Calcule impacto no preço de venda.</p>
        </div>
        <div class="border-l-4 border-[#002F74] pl-4">
          <h3 class="font-semibold text-[#001E40]">2029-2033 — IBS entra</h3>
          <p class="text-sm text-[#43474F]">IBS cresce 10% ao ano. ICMS/ISS reduz. Prepare-se para mudanças de alíquotas.</p>
        </div>
      </div>
    </section>
  </div>
</GlossaryPageLayout>